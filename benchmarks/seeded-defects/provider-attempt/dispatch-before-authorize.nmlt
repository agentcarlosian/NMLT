// Oracle: DispatchRequiresArm is refuted by one unauthorized dispatch.
// Current supported result: unknown (the frontend is structural only).
system DispatchBeforeAuthorizeMutant {
  state phase: Phase = proposed
  state armed: Bool = false
  state dispatched: Bool = false

  action dispatch { set dispatched = true }
  safety DispatchRequiresArm = always(dispatched implies armed)
}
