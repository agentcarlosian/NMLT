#lang rzk-1

-- A deliberately small directed seed. A refinement points from a concrete
-- state space to an abstract state space; no inverse is required or assumed.
#define Refinement
  ( Concrete Abstract : U)
  : U
  := Concrete -> Abstract

#define refinement-id
  ( A : U)
  : Refinement A A
  := \ x -> x

#define refinement-compose
  ( A B C : U)
  ( f : Refinement A B)
  ( g : Refinement B C)
  : Refinement A C
  := \ x -> g (f x)

-- Category laws stated pointwise, so no function extensionality axiom enters
-- the experiment.
#define refinement-left-identity
  ( A B : U)
  ( f : Refinement A B)
  ( x : A)
  : refinement-compose A A B (refinement-id A) f x = f x
  := refl

#define refinement-right-identity
  ( A B : U)
  ( f : Refinement A B)
  ( x : A)
  : refinement-compose A B B f (refinement-id B) x = f x
  := refl

#define refinement-associativity
  ( A B C D : U)
  ( f : Refinement A B)
  ( g : Refinement B C)
  ( h : Refinement C D)
  ( x : A)
  : refinement-compose A C D (refinement-compose A B C f g) h x
      = refinement-compose A B D f (refinement-compose B C D g h) x
  := refl

-- A refinement law transports a concrete observation into an abstract one.
-- Keeping the witness dependent makes the intended proof-relevant extension
-- visible without yet asserting a Segal-type result.
#define ObservationPreserving
  ( Concrete Abstract Observation : U)
  ( concrete-observe : Concrete -> Observation)
  ( abstract-observe : Abstract -> Observation)
  ( refine : Refinement Concrete Abstract)
  : U
  := (state : Concrete) ->
       abstract-observe (refine state) = concrete-observe state

-- Path composition is reproduced locally so this experiment has no imported
-- axiom for composing observation witnesses.
#define path-concat
  ( A : U)
  ( x y z : A)
  : ( x = y) -> (y = z) -> (x = z)
  := \ p -> idJ(
      A,
      x,
      ( \ y' _ -> ((y' = z) -> (x = z))),
      ( \ r -> r),
      y,
      p)

-- A refinement is now proof-relevant: it packages the directed map together
-- with its observation-preservation witness.
#define RefinementWitness
  ( Concrete Abstract Observation : U)
  ( concrete-observe : Concrete -> Observation)
  ( abstract-observe : Abstract -> Observation)
  : U
  := Sigma (refine : Refinement Concrete Abstract),
       ObservationPreserving Concrete Abstract Observation
         concrete-observe abstract-observe refine

#define refinement-witness-id
  ( State Observation : U)
  ( observe : State -> Observation)
  : RefinementWitness State State Observation observe observe
  := ( refinement-id State , \ _ -> refl)

#define refinement-witness-compose
  ( Concrete Middle Abstract Observation : U)
  ( concrete-observe : Concrete -> Observation)
  ( middle-observe : Middle -> Observation)
  ( abstract-observe : Abstract -> Observation)
  ( left : RefinementWitness Concrete Middle Observation
      concrete-observe middle-observe)
  ( right : RefinementWitness Middle Abstract Observation
      middle-observe abstract-observe)
  : RefinementWitness Concrete Abstract Observation
      concrete-observe abstract-observe
  := ( refinement-compose Concrete Middle Abstract (first left) (first right) ,
       \ state -> path-concat Observation
         (abstract-observe (first right (first left state)))
         (middle-observe (first left state))
         (concrete-observe state)
         (second right (first left state))
         (second left state))

#define refinement-witness-compose-map
  ( Concrete Middle Abstract Observation : U)
  ( concrete-observe : Concrete -> Observation)
  ( middle-observe : Middle -> Observation)
  ( abstract-observe : Abstract -> Observation)
  ( left : RefinementWitness Concrete Middle Observation
      concrete-observe middle-observe)
  ( right : RefinementWitness Middle Abstract Observation
      middle-observe abstract-observe)
  ( state : Concrete)
  : first (refinement-witness-compose Concrete Middle Abstract Observation
      concrete-observe middle-observe abstract-observe left right) state
      = first right (first left state)
  := refl
