{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nmlt.dev/schemas/expected-counterexample-v1.schema.json",
  "title": "NMLT expected counterexample oracle v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "witness_id",
    "status",
    "case_id",
    "property_id",
    "minimal_transition_count",
    "initial_observation",
    "steps",
    "violation",
    "normalization"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "witness_id": {
      "type": "string",
      "pattern": "^nmlt-expected-counterexample-v1:sha256:[0-9a-f]{64}$"
    },
    "status": { "const": "expected_not_observed" },
    "case_id": { "type": "string", "pattern": "^[a-z][a-z0-9-]+$" },
    "property_id": {
      "type": "string",
      "pattern": "^nmlt-benchmark-property-v1:sha256:[0-9a-f]{64}$"
    },
    "minimal_transition_count": { "type": "integer", "minimum": 0 },
    "initial_observation": { "type": "object" },
    "steps": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["action", "resulting_observation"],
        "properties": {
          "action": { "type": "string", "minLength": 1 },
          "resulting_observation": { "type": "object" }
        }
      }
    },
    "violation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state_index", "predicate", "explanation"],
      "properties": {
        "state_index": { "type": "integer", "minimum": 0 },
        "predicate": { "type": "string", "minLength": 1 },
        "explanation": { "type": "string", "minLength": 1 }
      }
    },
    "normalization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state_field_order", "transition_tie_break"],
      "properties": {
        "state_field_order": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "transition_tie_break": { "type": "string", "minLength": 1 }
      }
    }
  }
}
