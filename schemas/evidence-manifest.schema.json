{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nmlt.dev/schemas/evidence-manifest.schema.json",
  "title": "NMLT evidence manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "manifest_id",
    "artifact",
    "claim",
    "result",
    "method",
    "assumptions",
    "negative_controls",
    "residual_gaps"
  ],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "manifest_id": {
      "type": "string",
      "oneOf": [
        { "pattern": "^nmlt-evidence-v1:sha256:[0-9a-f]{64}$" },
        { "pattern": "^structural:.+$" }
      ],
      "$comment": "structural:* is a legacy noncanonical scaffold restricted to result unknown"
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "source_id": {
          "type": "string",
          "pattern": "^nmlt-source-v1:sha256:[0-9a-f]{64}$"
        },
        "source_set_id": {
          "type": "string",
          "pattern": "^nmlt-source-set-v1:sha256:[0-9a-f]{64}$"
        }
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": {
          "enum": [
            "well_formedness",
            "type_safety",
            "behavioral_safety",
            "behavioral_liveness",
            "refinement",
            "resource_bound",
            "evidence_integrity",
            "other"
          ]
        }
      }
    },
    "result": {
      "enum": [
        "proved",
        "model_checked",
        "tested",
        "monitored",
        "refuted",
        "unknown",
        "indeterminate"
      ]
    },
    "method": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "engine": { "type": "string", "minLength": 1 },
        "engine_version": { "type": "string", "minLength": 1 },
        "engine_source_set_id": {
          "type": "string",
          "pattern": "^nmlt-(?:[a-z0-9-]+-)?source-set-v[0-9]+:sha256:[0-9a-f]{64}$"
        },
        "engine_executable_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "configuration_id": {
          "type": "string",
          "pattern": "^nmlt-config-v1:sha256:[0-9a-f]{64}$"
        },
        "bounds": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "observations": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "trusted_components": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/trustedComponent" }
    },
    "certificate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "reference"],
      "properties": {
        "format": { "type": "string", "minLength": 1 },
        "reference": { "$ref": "#/$defs/rawSha256" },
        "path": { "type": "string", "minLength": 1 }
      }
    },
    "witness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "reference"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "reference": { "$ref": "#/$defs/contentAddressWithFragment" }
      }
    },
    "negative_controls": {
      "type": "array",
      "items": { "$ref": "#/$defs/contentAddress" }
    },
    "residual_gaps": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "rawSha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "contentAddress": {
      "type": "string",
      "pattern": "^(?:sha256:[0-9a-f]{64}|nmlt-[a-z0-9-]+:sha256:[0-9a-f]{64})$"
    },
    "contentAddressWithFragment": {
      "type": "string",
      "pattern": "^(?:sha256:[0-9a-f]{64}|nmlt-[a-z0-9-]+:sha256:[0-9a-f]{64})(?:#[A-Za-z0-9._~=%&+/-]+)?$"
    },
    "trustedComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "identity"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_.-]*$"
        },
        "identity": { "$ref": "#/$defs/contentAddress" }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "manifest_id": { "pattern": "^structural:" } },
        "required": ["manifest_id"]
      },
      "then": {
        "properties": { "result": { "const": "unknown" } }
      }
    },
    {
      "if": {
        "properties": {
          "result": {
            "enum": ["proved", "model_checked", "tested", "monitored", "refuted"]
          }
        },
        "required": ["result"]
      },
      "then": {
        "required": ["scope", "trusted_components"],
        "properties": {
          "artifact": {
            "oneOf": [
              { "required": ["source_id"] },
              { "required": ["source_set_id"] }
            ]
          },
          "method": {
            "required": [
              "engine",
              "engine_version",
              "engine_source_set_id",
              "engine_executable_sha256"
            ]
          },
          "scope": { "required": ["configuration_id"] },
          "claim": {
            "properties": {
              "id": { "$ref": "#/$defs/contentAddress" }
            }
          },
          "trusted_components": { "minItems": 1 }
        }
      }
    },
    {
      "if": {
        "properties": { "result": { "const": "model_checked" } },
        "required": ["result"]
      },
      "then": {
        "required": ["scope"],
        "properties": {
          "scope": {
            "required": ["bounds"],
            "properties": { "bounds": { "minItems": 1 } }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "result": { "const": "proved" } },
        "required": ["result"]
      },
      "then": {
        "required": ["certificate"],
        "properties": {
          "certificate": { "required": ["path"] }
        }
      }
    },
    {
      "if": {
        "properties": { "result": { "const": "refuted" } },
        "required": ["result"]
      },
      "then": { "required": ["witness"] }
    }
  ]
}
