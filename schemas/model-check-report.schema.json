{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nmlt.dev/schemas/model-check-report.schema.json",
  "title": "NMLT deterministic model-check report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "semantic_binding",
    "system",
    "result",
    "complete",
    "explored_states",
    "explored_transitions",
    "bounds",
    "properties"
  ],
  "properties": {
    "schema_version": { "const": "1.1.0" },
    "semantic_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_set_id",
        "module_map_id",
        "surface_program_id",
        "resolved_hir_id",
        "core_program_id",
        "ruleset_bundle_id",
        "resource_policy_id",
        "certificate_id",
        "kernel_profile_id"
      ],
      "properties": {
        "source_set_id": { "type": "string", "pattern": "^nmlt-source-set-v1:sha256:[0-9a-f]{64}$" },
        "module_map_id": { "type": "string", "pattern": "^nmlt-module-map-v1:sha256:[0-9a-f]{64}$" },
        "surface_program_id": { "type": "string", "pattern": "^nmlt-surface-program-v1:sha256:[0-9a-f]{64}$" },
        "resolved_hir_id": { "type": "string", "pattern": "^nmlt-hir-resolution-v3:sha256:[0-9a-f]{64}$" },
        "core_program_id": { "type": "string", "pattern": "^nmlt-core-program-v1:sha256:[0-9a-f]{64}$" },
        "ruleset_bundle_id": { "type": "string", "pattern": "^nmlt-ruleset-bundle-v1:sha256:[0-9a-f]{64}$" },
        "resource_policy_id": { "type": "string", "pattern": "^nmlt-kernel-policy-v1:sha256:[0-9a-f]{64}$" },
        "certificate_id": { "type": "string", "pattern": "^nmlt-elaboration-certificate-v1:sha256:[0-9a-f]{64}$" },
        "kernel_profile_id": { "type": "string", "pattern": "^nmlt-kernel-profile-v1:sha256:[0-9a-f]{64}$" }
      }
    },
    "system": { "type": "string", "minLength": 1 },
    "result": { "$ref": "#/$defs/result" },
    "complete": { "type": "boolean" },
    "explored_states": { "type": "integer", "minimum": 1 },
    "explored_transitions": { "type": "integer", "minimum": 0 },
    "bounds": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_states", "max_depth"],
      "properties": {
        "max_states": { "type": "integer", "minimum": 1 },
        "max_depth": { "type": "integer", "minimum": 0 }
      }
    },
    "properties": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["property", "result", "reason", "witness"],
        "properties": {
          "property": { "type": "string", "minLength": 1 },
          "result": { "$ref": "#/$defs/result" },
          "reason": { "type": "string", "minLength": 1 },
          "witness": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "required": ["steps"],
            "properties": {
              "steps": {
                "type": "array",
                "minItems": 1,
                "items": { "$ref": "#/$defs/step" }
              }
            }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "result": { "const": "model_checked" } },
        "required": ["result"]
      },
      "then": {
        "properties": { "complete": { "const": true } }
      }
    }
  ],
  "$defs": {
    "result": {
      "enum": ["model_checked", "refuted", "unknown"]
    },
    "value": {
      "type": ["boolean", "integer", "string"]
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["index", "action", "state", "available_capabilities", "enabled_actions"],
      "properties": {
        "index": { "type": "integer", "minimum": 0 },
        "action": { "type": ["string", "null"] },
        "state": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/value" }
        },
        "available_capabilities": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "enabled_actions": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      }
    }
  }
}
