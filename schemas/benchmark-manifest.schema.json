{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nmlt.dev/schemas/benchmark-manifest.schema.json",
  "title": "NMLT benchmark manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "suite_id", "cases"],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "suite_id": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "path", "class", "expected", "support"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "class": {
            "enum": ["reference", "semantic_mutant", "malformed", "stress"]
          },
          "property": { "type": "string" },
          "expected": {
            "enum": ["accepted", "refuted", "rejected", "unknown"]
          },
          "support": { "enum": ["current", "planned"] },
          "origin": { "type": "string" }
        }
      }
    }
  }
}
